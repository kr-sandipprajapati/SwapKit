{
  "dependencies": {
    "@swapkit/helpers": "workspace:*",
    "@swapkit/toolbox-evm": "workspace:*",
    "@swapkit/toolbox-utxo": "workspace:*",
    "@trezor/connect-web": "9.4.0"
  },
  "description": "Clone of SwapKit Wallet - Trezor compatible to webpack",
  "files": [
    "src/",
    "dist/"
  ],
  "homepage": "https://github.com/knackroot-technolabs-llp/SwapKit",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "name": "@knackroot/wallet-trezor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knackroot-technolabs-llp/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
